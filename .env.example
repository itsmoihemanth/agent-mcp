# =============================================================================
# AgentMCP Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env

# -----------------------------------------------------------------------------
# LLM API (OpenAI-compatible — works with OpenAI, LiteLLM, Azure, etc.)
# -----------------------------------------------------------------------------

# Required: API key for the LLM provider
OPENAI_API_KEY=your-api-key-here

# Optional: Custom base URL for OpenAI-compatible proxies (LiteLLM, Azure, etc.)
# Leave empty to use OpenAI directly
OPENAI_API_BASE=

# Optional: Tavily API key for web search tool
# Free tier available at https://tavily.com — the agent works without it
TAVILY_API_KEY=your-tavily-api-key-here

# -----------------------------------------------------------------------------
# Model Configuration
# -----------------------------------------------------------------------------

# Chat model (default: gpt-4.1-mini — balanced cost/quality)
# Available via LiteLLM: gpt-3.5-turbo, gpt-4.1-mini, gpt-5-mini, gpt-4o-mini
MODEL_NAME=gpt-4.1-mini

# Embedding model for RAG vector store
EMBEDDING_MODEL=text-embedding-3-small

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# PostgreSQL + pgvector connection string (matches docker-compose service name)
DATABASE_URL=postgresql+psycopg://agent:agent@db:5432/agentmcp

# -----------------------------------------------------------------------------
# MCP Server
# -----------------------------------------------------------------------------

# Path to the MCP file reader server script (relative to app root)
MCP_FILE_READER_PATH=src/mcp_servers/file_reader.py

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# JSON-structured logs (set to true for production, false for local dev)
LOG_JSON=true
